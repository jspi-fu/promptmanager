{
    "manifest_version": 3,
    "default_locale": "zh_CN",
    "name": "PromptMaster",
    "version": "2.7.1",
    "description": "开源提示词管理器，拥有跨AI平台提示词管理、提示词生成、提示词市场等功能，支持 ChatGPT、Gemini、豆包、千问 等24个 AI 平台。",
    "permissions": [
        "sidePanel",
        "storage",
        "tabs",
        "scripting",
        "activeTab",
        "contextMenus"
    ],
    "side_panel": {
        "default_path": "sidepanel/index.html"
    },
    "icons": {
        "16": "/icons/icon16.png",
        "48": "/icons/icon48.png",
        "128": "/icons/icon128.png"
    },
    "action": {
        "default_title": "打开侧边栏",
        "default_icon": {
            "16": "/icons/icon16.png",
            "48": "/icons/icon48.png",
            "128": "/icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "host_permissions": [
        "https://gitee.com/*"
    ],
    "optional_host_permissions": [
        "<all_urls>"
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*",
                "info.html",
                "promptStorage.js",
                "utils.js",
                "llm_providers.json",
                "system.md"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}